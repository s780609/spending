# Neon 資料庫連線字串（Neon 主控台 → Connect → Connection string）
DATABASE_URL=postgresql://USER:PASSWORD@xxx.neon.tech/neondb?sslmode=require

# 網站登入密碼（自訂）
APP_PASSWORD=change-me

# 簽署登入 cookie 用的隨機字串（自訂一長串亂數即可）
AUTH_SECRET=change-me-to-a-long-random-string

# Vercel Cron 呼叫 /api/snapshot 的驗證密鑰（自訂隨機字串，Vercel 會自動帶在 Authorization header）
CRON_SECRET=change-me-to-another-random-string
